{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:bk-ui:schema:component-manifest:1",
  "title": "BK-UI component installation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "name",
    "title",
    "componentVersion",
    "description",
    "repository",
    "sourceCommit",
    "license",
    "react",
    "next",
    "files",
    "dependencies",
    "entrypoints",
    "tailwind",
    "constraints",
    "examples"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "componentVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "format": "uri" },
    "sourceCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spdx", "status"],
      "properties": {
        "spdx": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pending", "approved"] }
      }
    },
    "react": {
      "type": "object",
      "additionalProperties": false,
      "required": ["range", "tested"],
      "properties": {
        "range": { "type": "string", "minLength": 1 },
        "tested": { "type": "string", "minLength": 1 }
      }
    },
    "next": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tested", "clientBoundary", "serializableProps"],
      "properties": {
        "tested": { "type": "string", "minLength": 1 },
        "clientBoundary": { "$ref": "#/$defs/relativePath" },
        "serializableProps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "type", "frameworks"],
        "properties": {
          "source": { "$ref": "#/$defs/relativePath" },
          "target": {
            "type": "string",
            "pattern": "^@components/[A-Za-z0-9_./-]+$"
          },
          "type": {
            "enum": [
              "registry:component",
              "registry:hook",
              "registry:lib",
              "registry:file"
            ]
          },
          "frameworks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["react", "next"] }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["common", "tailwind"],
      "properties": {
        "common": { "$ref": "#/$defs/dependencyList" },
        "tailwind": {
          "type": "object",
          "additionalProperties": false,
          "required": ["3", "4"],
          "properties": {
            "3": { "$ref": "#/$defs/dependencyList" },
            "4": { "$ref": "#/$defs/dependencyList" }
          }
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["react", "next"],
      "properties": {
        "react": { "$ref": "#/$defs/relativePath" },
        "next": { "$ref": "#/$defs/relativePath" }
      }
    },
    "tailwind": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supportedMajors", "3", "4"],
      "properties": {
        "supportedMajors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": [3, 4] }
        },
        "3": { "$ref": "#/$defs/tailwindMajor" },
        "4": { "$ref": "#/$defs/tailwindMajor" }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ssr", "accessibility"],
      "properties": {
        "ssr": { "$ref": "#/$defs/constraintList" },
        "accessibility": { "$ref": "#/$defs/constraintList" }
      }
    },
    "examples": {
      "type": "object",
      "additionalProperties": false,
      "required": ["react", "nextClient", "nextServer"],
      "properties": {
        "react": { "type": "string", "minLength": 1, "maxLength": 65536 },
        "nextClient": {
          "type": "string",
          "minLength": 1,
          "maxLength": 65536
        },
        "nextServer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 65536
        }
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./-]+$"
    },
    "dependencyList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "constraintList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 1024 }
    },
    "tailwindMajor": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supported",
            "range",
            "tested",
            "itemName",
            "scan",
            "representativeClasses"
          ],
          "properties": {
            "supported": { "const": true },
            "range": { "type": "string", "minLength": 1 },
            "tested": { "type": "string", "minLength": 1 },
            "itemName": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "scan": { "type": "string", "minLength": 1 },
            "representativeClasses": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["supported", "reason"],
          "properties": {
            "supported": { "const": false },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
